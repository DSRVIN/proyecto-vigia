# VIGÍA — Variables de entorno
# Copia este archivo como `.env` y completa los valores reales.
# NUNCA subas el archivo .env al repositorio.

# URL del proyecto Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anónima de Supabase (segura para el frontend)
VITE_SUPABASE_ANON_KEY=tu-anon-key

# API Key de Google Gemini (https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=tu-gemini-api-key

# NOTA: la service_role key de Supabase NUNCA va aquí ni en el frontend.
# Solo debe usarse en servicios de backend (p. ej. credenciales de n8n).
